# --- Database (required) ---
# Either set DATABASE_URL (preferred for Vercel) ...
DATABASE_URL=postgres://dreamscape:PASSWORD@cmh-prd-daydream-backend.cluster-cxbk3xgompqu.us-east-2.rds.amazonaws.com:5432/cloud_services

# ... or set the discrete vars instead (DATABASE_URL takes precedence if both set):
# PG_HOST=cmh-prd-daydream-backend.cluster-cxbk3xgompqu.us-east-2.rds.amazonaws.com
# PG_PORT=5432
# PG_DATABASE=cloud_services
# PG_USER=dreamscape
# PG_PASSWORD=

# Set to "disable" only for a local non-SSL Postgres. RDS needs SSL (default on).
# PGSSL=disable

# --- Optional shared secret (webhook collector only) ---
# If set, callers must send "Authorization: Bearer <INGEST_TOKEN>".
# Leave unset to keep the endpoint open (matches the current collector).
# INGEST_TOKEN=

# --- MCP connector (authenticated, captures user identity via Auth0) ---
# Auth0 tenant issuer (no trailing slash). Same tenant as the portal app.
AUTH0_ISSUER_BASE_URL=https://sbi-pro.us.auth0.com
# The Auth0 API identifier for this MCP server. MUST equal the canonical MCP
# resource URL exactly (this is what Claude sends as the RFC 8707 `resource`).
AUTH0_AUDIENCE=https://sbi-telemetry.vercel.app/api/mcp
# Optional: custom claim that carries the email if you add an Auth0 Action.
# (Auth0 access tokens don't include email by default. See README.)
# AUTH0_EMAIL_CLAIM=https://sbi.com/email
# Optional fallback: resolve email from Auth0 /userinfo when not in the token.
# AUTH0_FETCH_USERINFO=true
